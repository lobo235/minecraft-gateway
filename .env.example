# nomad-gateway URL and API key (for RCON allocation resolution).
NOMAD_GATEWAY_URL=http://nomad-gateway.example.com:8080
NOMAD_GATEWAY_KEY=your-nomad-gateway-api-key-here

# vault-gateway URL and API key (for RCON password retrieval).
VAULT_GATEWAY_URL=http://vault-gateway.example.com:8080
VAULT_GATEWAY_KEY=your-vault-gateway-api-key-here

# Bearer token callers must present to use this API.
GATEWAY_API_KEY=your-gateway-api-key-here

# Port this gateway listens on. Default: 8080
PORT=8080

# Log level: debug, info, warn, error. Default: info
LOG_LEVEL=info
